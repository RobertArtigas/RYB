#ENDSHEET
#!--------------------------------------------------------------------
#! #GLOBALDATA
#! %TryExpireGoVar BYTE(FALSE)
#! #ENDGLOBALDATA
#!--------------------------------------------------------------------
#AT(%GlobalData)
#IF(%DoExpire=1)
  #IF(%DoGo=1)
%TryExpireGoVar BYTE(FALSE)
  #ENDIF
#ENDIF
#ENDAT
#!--------------------------------------------------------------------
#! %ProcedureTemplate = 'Source'
#! %ProcedureTemplate = 'Window'
#! %ProcedureTemplate = 'Frame'
#! %ProcedureTemplate = 'Process'
#! %ProcedureTemplate = 'Report'
#! %ProcedureTemplate = 'Todo'
#AT(%DataSection)
 #IF(%DoExpire)
 #ENDIF
#ENDAT
#! %ProcedureTemplate = 'Source'
#AT(%ProcessedCode),FIRST
 #IF(%DoExpire)
  ! RYB-BEG-EXPIRE: Try, Expire, and Go Application
  #IF(%DoGo)
  IF NOT %TryExpireGoVar
    IF TODAY() >= DATE(%ExpMonth, %ExpDay, %ExpYear) THEN
      HALT (0, '%ExpMsg')
    END
  END
  #ELSE
  IF TODAY() >= DATE(%ExpMonth, %ExpDay, %ExpYear) THEN
    HALT (0, '%ExpMsg')
  END
  #ENDIF
  ! RYB-END-EXPIRE: Try, Expire, and Go Application
 #ENDIF
#ENDAT
#! %ProcedureTemplate = 'Window'
#! %ProcedureTemplate = 'Frame'
#! %ProcedureTemplate = 'Process'
#! %ProcedureTemplate = 'Report'
#! %ProcedureTemplate = 'Todo'
#AT(%ProcedureInitialize),FIRST
 #IF(%DoExpire)
! RYB-BEG-EXPIRE: Try, Expire, and Go Application
  #IF(%DoGo)
IF NOT %TryExpireGoVar
  IF TODAY() >= DATE(%ExpMonth, %ExpDay, %ExpYear) THEN
    HALT (0, '%ExpMsg')
  END
END
  #ELSE
IF TODAY() >= DATE(%ExpMonth, %ExpDay, %ExpYear) THEN
  HALT (0, '%ExpMsg')
END
  #ENDIF
! RYB-END-EXPIRE: Try, Expire, and Go Application
 #ENDIF
#ENDAT
