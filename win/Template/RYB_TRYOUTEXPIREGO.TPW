#EXTENSION(RYB_TryExpireGo,'RA.2026.02.16: Try, Expire, and Go (CLARION,ABC)'),DESCRIPTION('RYB | Try, Expire, and Go Application. Version: ' & %tplVersionTRYEXPIREGO & ', Release: ' & %tplReleaseTRYEXPIREGO),APPLICATION
